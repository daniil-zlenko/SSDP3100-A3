<section class="panel">
  <h2>Contact Submissions</h2>
  <p><a href="/admin">&larr; Dashboard</a></p>

  <% if (contacts.length === 0) { %>
    <p>No submissions yet.</p>
  <% } else { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Name</th>
          <th>Email</th>
          <th>Message</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(function(contact) { %>
          <tr id="contact-<%= contact._id %>" class="<%= contact.isRead ? 'is-read' : 'is-unread' %>">
            <td><%= new Date(contact.postedDate).toLocaleDateString() %></td>
            <td><%= contact.name %></td>
            <td><a href="mailto:<%= contact.email %>"><%= contact.email %></a></td>
            <td class="message-cell"><%= contact.message %></td>
            <td>
              <span class="badge <%= contact.isRead ? 'badge-read' : 'badge-unread' %>">
                <%= contact.isRead ? 'Read' : 'Unread' %>
              </span>
            </td>
            <td class="action-cell">
              <button
                class="btn-toggle-read"
                data-id="<%= contact._id %>"
                title="Toggle read status"
              ><%= contact.isRead ? 'Mark Unread' : 'Mark Read' %></button>
              <button
                class="btn-delete"
                data-id="<%= contact._id %>"
                data-type="contact"
                title="Delete submission"
              >Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<script>
document.querySelectorAll('.btn-toggle-read').forEach(function(btn) {
  btn.addEventListener('click', async function() {
    const id = this.dataset.id;
    const res = await fetch('/admin/contacts/' + id + '/read', { method: 'PATCH' });
    if (res.ok) {
      const data = await res.json();
      const row = document.getElementById('contact-' + id);
      const badge = row.querySelector('.badge');
      row.classList.toggle('is-read', data.isRead);
      row.classList.toggle('is-unread', !data.isRead);
      badge.textContent = data.isRead ? 'Read' : 'Unread';
      badge.className = 'badge ' + (data.isRead ? 'badge-read' : 'badge-unread');
      this.textContent = data.isRead ? 'Mark Unread' : 'Mark Read';
    }
  });
});

document.querySelectorAll('.btn-delete[data-type="contact"]').forEach(function(btn) {
  btn.addEventListener('click', async function() {
    if (!confirm('Delete this submission?')) return;
    const id = this.dataset.id;
    const res = await fetch('/admin/contacts/' + id, { method: 'DELETE' });
    if (res.ok) {
      document.getElementById('contact-' + id).remove();
    }
  });
});
</script>
