<section class="panel">
  <h2><% if (typeof category !== 'undefined' && category) { %>Projects in "<%= category.name %>"<% } else { %>Active Projects<% } %></h2>

  <form method="GET" action="<% if (typeof category !== 'undefined' && category) { %>/projects/category/<%= category.slug %><% } else { %>/projects<% } %>" class="search-form">
    <input
      type="text"
      name="q"
      value="<%= q %>"
      placeholder="Search by title, description, tags..."
    />
    <input
      type="text"
      name="tag"
      value="<%= tag %>"
      placeholder="Filter by tag..."
    />
    <button type="submit">Search</button>
    <% if (q || tag) { %>
      <a href="<% if (typeof category !== 'undefined' && category) { %>/projects/category/<%= category.slug %><% } else { %>/projects<% } %>" class="clear-search">Clear</a>
    <% } %>
  </form>

  <% if (q || tag) { %>
    <p class="search-info">
      <% if (q) { %>Searching for <strong>"<%= q %>"</strong><% } %>
      <% if (q && tag) { %> &middot; <% } %>
      <% if (tag) { %>Tag: <strong><%= tag %></strong><% } %>
      &mdash; <%= projects.length %> project<%= projects.length !== 1 ? 's' : '' %> found.
    </p>
  <% } %>

  <% if (projects.length === 0) { %>
    <p>No projects found<% if (q || tag) { %> matching your filters<% } %>.</p>
  <% } else { %>
    <div class="projects-grid">
      <% projects.forEach(function(project) { %>
        <%- include('partials/project-card', { project: project }) %>
      <% }); %>
    </div>
  <% } %>
</section>
