<article class="project-detail panel">
  <h2><%= project.title %></h2>

  <% if (project.categoryId && project.categoryId.name) { %>
    <p class="project-category">
      Category: <a href="/projects/category/<%= project.categoryId.slug %>"><%= project.categoryId.name %></a>
    </p>
  <% } %>

  <p><%= project.description %></p>

  <% if (project.tags && project.tags.length) { %>
    <div class="tags">
      <% project.tags.forEach(function(tag) { %>
        <a href="/projects?tag=<%= tag.name %>" class="tag"><%= tag.name %></a>
      <% }); %>
    </div>
  <% } %>

  <p style="margin-top: 1.5rem;">
    <a href="/projects">&larr; Back to Projects</a>
  </p>
</article>
